  "factors": [
    {
      "id": "F001",
      "name": "短期反转(成交量加权)",
      "category": "反转/动量",
      "source_papers": ["Jegadeesh & Titman (1993)", "Hong & Stein (1999)"],
      "a_share_validation": "强 (A股散户主导，过度反应显著)",
      "definition": {
        "formula": "-rank(ts_mean(ret_20d * volume_20d, 20) / ts_mean(volume_20d, 20))",
        "explanation": "过去20日成交量加权平均收益，取负值排序。高成交量下的反转更强(散户过度反应)。",
        "expected_ic_sign": "negative",
        "expected_ic_magnitude": "0.03 - 0.06"
      },
      "required_fields": ["close", "volume"],
      "derived_fields": ["ret_20d", "volume_20d"],
      "calculation": {
        "steps": [
          "1. 计算20日收益率 ret_20d = (close / delay(close,20)) - 1",
          "2. 计算20日成交量 volume_20d = ts_mean(volume, 20)",
          "3. 计算成交量加权收益 vwap_ret = ret_20d * volume_20d / ts_mean(volume_20d, 20)",
          "4. 取负值并排序 -rank(vwap_ret)"
        ],
        "python_signature": "def short_term_reversal_vw(close: pd.Series, volume: pd.Series, window: int = 20) -> pd.Series"
      },
      "expected_effect": {
        "ic_improvement": "+0.03 to +0.05",
        "sharpe_lift": "+0.15 to +0.30",
        "drawdown_impact": "中性或轻微改善",
        "turnover": "月度40-50%(需平滑)",
        "decay_halflife": "5-10天"
      },
      "test_logic": [
        "test_ic_negative: IC均值 < 0",
        "test_size_corr_low: 中性化后|size_corr| < 0.15",
        "test_turnover_reasonable: 月度换手率 < 50%",
        "test_high_volume_stronger: 高成交量子样本IC绝对值 > 低成交量子样本"
      ],
      "priority": "P0",
      "dependencies": [],
      "estimated_effort": "1h"
    },
    {
      "id": "F002",
      "name": "彩票偏好规避",
      "category": "行为金融/散户",
      "source_papers": ["Bali et al. (2011)", "Stambaugh et al. (2012)"],
      "a_share_validation": "强 (A股散户彩票偏好显著)",
      "definition": {
        "formula": "-(MAX_20d / VOL_20d * 0.5 + rank(ivol_20d) * 0.3 + rank(skew_20d) * 0.2)",
        "explanation": "规避高最大日收益(MAX)、高特质波动率(ivol)、高偏度(skew)的股票。这些特征吸引散户过度追捧，导致未来低收益。",
        "expected_ic_sign": "negative",
        "expected_ic_magnitude": "0.02 - 0.04"
      },
      "required_fields": ["high", "low", "close", "volume"],
      "derived_fields": ["MAX_20d", "ivol_20d", "skew_20d"],
      "calculation": {
        "steps": [
          "1. MAX_20d = ts_max(high/close - 1, 20)  # 20日内最大日收益",
          "2. ivol_20d = std(residuals from market regression, 20)  # 特质波动率",
          "3. skew_20d = skew(ret, 20)  # 日收益偏度",
          "4. 组合 = -(MAX_20d * 0.5 + rank(ivol) * 0.3 + rank(skew) * 0.2)"
        ],
        "python_signature": "def lottery_avoidance(high: pd.Series, low: pd.Series, close: pd.Series, volume: pd.Series, market_ret: pd.Series, window: int = 20) -> pd.Series"
      },
      "expected_effect": {
        "ic_improvement": "+0.02 to +0.04",
        "sharpe_lift": "+0.10 to +0.20",
        "drawdown_impact": "改善(降低极端波动暴露)",
        "turnover": "月度30-40%",
        "decay_halflife": "15-25天"
      },
      "test_logic": [
        "test_ic_negative: 因子IC均值 < 0",
        "test_corr_with_reversal: |corr(F002, F001)| < 0.5",
        "test_high_max_underperform: MAX前20%组合未来收益 < MAX后20%"
      ],
      "priority": "P0",
      "dependencies": ["F001"],
      "estimated_effort": "1.5h"
    },
    {
      "id": "F003",
      "name": "股东集中度",
      "category": "行为金融/机构",
      "source_papers": ["Campbell et al. (2008)", "中国A股筹码集中度研究"],
      "a_share_validation": "中(数据可得性受限)",
      "definition": {
        "formula": "-pct_change(shareholders, 1q) 或 -turnover_rank + ret_20d_rank * 0.5",
        "explanation": "股东户数减少=筹码集中(机构吸筹)。无股东数据时，用高换手率+近期正收益作为proxy。",
        "expected_ic_sign": "positive",
        "expected_ic_magnitude": "0.02 - 0.03"
      },
      "required_fields": ["shareholders"],
      "fallback_fields": ["volume", "close"],
      "derived_fields": ["shareholder_change", "turnover_rank", "ret_20d_rank"],
      "calculation": {
        "steps": [
          "PRIMARY: 1. 获取季度股东户数 shareholders",
          "PRIMARY: 2. 计算季度变化率 pct_change(shareholders, 1q)",
          "PRIMARY: 3. 取负值 -pct_change(shareholders) # 减少=正信号",
          "FALLBACK: 1. 计算20日换手率 turnover = volume / float_shares",
          "FALLBACK: 2. 计算20日收益 rank",
          "FALLBACK: 3. 组合 = -rank(turnover) + rank(ret_20d) * 0.5"
        ],
        "python_signature": "def shareholder_concentration(shareholders: pd.Series = None, volume: pd.Series = None, close: pd.Series = None, float_shares: pd.Series = None) -> pd.Series"
      },
      "expected_effect": {
        "ic_improvement": "+0.02 to +0.03",
        "sharpe_lift": "+0.05 to +0.15",
        "drawdown_impact": "轻微改善",
        "turnover": "月度20-30%(低频)",
        "decay_halflife": "30-60天"
      },
      "test_logic": [
        "test_fallback_works: 无shareholders列时fallback逻辑正确",
        "test_positive_ic: 筹码集中应有正IC",
        "test_low_turnover: fallback版本月度换手率 < 30%"
      ],
      "priority": "P1",
      "dependencies": [],
      "estimated_effort": "1h"
    },
    {
