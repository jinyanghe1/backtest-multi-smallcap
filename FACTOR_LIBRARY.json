      "required_fields": ["close"],
      "derived_fields": ["ret_5d", "ret_20d"],
      "calculation": {
        "steps": [
          "1. ret_5d = (close / delay(close,5)) - 1",
          "2. ret_20d = (close / delay(close,20)) - 1",
          "3. acceleration = ret_5d / (abs(ret_20d) + 0.01) - 1"
        ],
        "python_signature": "def earnings_acceleration_proxy(close: pd.Series, short_window: int = 5, long_window: int = 20) -> pd.Series"
      },
      "expected_effect": {
        "ic_improvement": "+0.02 to +0.04",
        "sharpe_lift": "+0.05 to +0.15",
